# GuardianStreams Billing System — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Email (Gmail recommended) ──────────────────────────────
EMAIL_ENABLED=false
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=you@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM=billing@guardianstreams.com
EMAIL_FROM_NAME=GuardianStreams Billing

# ── Telegram ───────────────────────────────────────────────
# Get a bot token from @BotFather, then message your bot
# and visit https://api.telegram.org/bot<TOKEN>/getUpdates
# to find your chat_id.
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Discord ────────────────────────────────────────────────
# Create a webhook in your Discord server under
# Channel Settings → Integrations → Webhooks.
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=

# ── Pushover ───────────────────────────────────────────────
# Register at https://pushover.net to get your user key
# and create an application for the API token.
PUSHOVER_ENABLED=false
PUSHOVER_API_TOKEN=
PUSHOVER_USER_KEY=
